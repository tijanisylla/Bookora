# Use mock data from src/data/properties.ts (default when unset or not "false")
VITE_USE_MOCK_DATA=true

# WordPress REST API base (no trailing slash).
# Direct to the site (enable CORS for your dev origin), or same-origin proxy:
# VITE_WP_API_BASE=/wp-json/wp/v2
VITE_WP_API_BASE=http://bookora.local/wp-json/wp/v2

# Firebase Auth (Email/Password + Google/Facebook)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: if set, user-submitted listings are also published to WordPress.
# Use a WP user + Application Password with permission to create `properties`.
VITE_WP_SYNC_USERNAME=your_wp_username
VITE_WP_SYNC_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
